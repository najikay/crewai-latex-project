# ===========================================================================
# NavigatorCrew .gitignore
# Safe for: git add .
# ===========================================================================

# --- Sensitive / Personal ---
.env

# --- Course materials (large PDFs, not part of source code) ---
homework/
material/
software_submission_guidelines-V3.pdf

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env/
.pytest_cache/
*.egg-info/
dist/
build/

# --- LaTeX build artifacts ---
*.aux
*.log
*.toc
*.out
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.synctex.gz
*.synctex(busy)
latex/main.pdf
latex/venv/

# --- Runtime outputs (generated on each run) ---
outputs/smoke_test.txt
outputs/smoke_run*.txt
outputs/run_log.txt
outputs/researchcrew.log
outputs/current_run_folder.txt
outputs/research_briefs.md
outputs/paper_outline.md
outputs/quality_report.md
outputs/token_report.md
outputs/figures_manifest.md
outputs/hebrew_prose.md
outputs/latex_status.md
outputs/NavigatorCrew_paper.pdf
outputs/current/

# --- Agent-generated LaTeX files (regenerated each run, not source code) ---
# Only cover.tex is static; all content chapters are agent-written.
latex/figures/*.png
latex/chapters/abstract.tex
latex/chapters/ch01_intro.tex
latex/chapters/ch02_bio_basis.tex
latex/chapters/ch03_sensors.tex
latex/chapters/ch04_slam.tex
latex/chapters/ch05_fusion.tex
latex/chapters/ch06_algorithm.tex
latex/chapters/ch07_oursystem.tex
latex/chapters/ch08_results.tex
latex/chapters/ch09_conclusion.tex

# --- Per-run archives (large, reproducible — keep out of git) ---
outputs/runs/*
!outputs/runs/.gitkeep

# --- Claude Code ---
.claude/

# --- Editor / OS ---
.DS_Store
Thumbs.db
*.swp
*.swo
