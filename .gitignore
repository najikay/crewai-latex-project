# ===========================================================================
# NavigatorCrew .gitignore
# Safe for: git add .
# ===========================================================================

# --- Sensitive / Personal ---
.env

# --- Course materials (large PDFs, not part of source code) ---
homework/
material/
software_submission_guidelines-V3.pdf

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env/
.pytest_cache/
*.egg-info/
dist/
build/

# --- LaTeX build artifacts ---
*.aux
*.log
*.toc
*.out
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.synctex.gz
*.synctex(busy)
latex/main.pdf
latex/venv/

# --- Runtime outputs (generated on each run) ---
outputs/smoke_test.txt
outputs/run_log.txt
outputs/researchcrew.log
outputs/research_briefs.md
outputs/paper_outline.md
outputs/quality_report.md
outputs/token_report.md
outputs/figures_manifest.md

# Keep the final deliverable PDF
!outputs/NavigatorCrew_paper.pdf

# --- Editor / OS ---
.DS_Store
Thumbs.db
*.swp
*.swo
