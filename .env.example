# ResearchCrew API Keys
# Copy this file to .env and fill in your keys

# --- Required Keys ---
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Get your free key at: https://serper.dev/
SERPER_API_KEY=your_serper_key_here

# --- Optional Keys ---
# Required only if you want to use OpenAI's 'text-embedding-3-small' model for memory.
# If left blank, the system will fallback to local HuggingFace embeddings.
OPENAI_API_KEY=your_openai_key_here

# --- Runtime Configuration ---
# LOG_LEVEL=INFO
# CREWAI_MODEL=claude-sonnet-4-6
