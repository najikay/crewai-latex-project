# NavigatorCrew — Environment Variables
# Copy to .env and fill in your keys. Never commit .env.

# --- DeepSeek (primary LLM provider) ---
# Get your key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...
ACTIVE_PROVIDER=deepseek

# --- Serper (web search for SLAMResearcher) ---
# Free key at: https://serper.dev/
SERPER_API_KEY=...
